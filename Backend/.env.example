# MongoDB Configuration
MONGODB_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app_name>"
MONGODB_DB_NAME="interactive_story"

# JWT Configuration
# MUST be changed in production to a secure random string (e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY="your-super-secret-key-for-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Configuration (JSON array)
# Update this to only include your actual production domain when deployed
CORS_ORIGINS=["https://yourdomain.com", "http://yourdomain.com"]

# Google GenAI / Gemini Configuration
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY="your-google-api-key"

# SiliconFlow Configuration
SILICONFLOW_API_KEY="your-siliconflow-api-key"

# ADK Session Database (used by Google Agent Development Kit)
DATABASE_URL="sqlite+aiosqlite:///agent/db/session.db"
